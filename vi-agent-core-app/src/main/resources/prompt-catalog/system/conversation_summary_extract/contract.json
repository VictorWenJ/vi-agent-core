{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "x-structuredOutputContractKey": "conversation_summary_output",
  "x-outputTarget": "conversation_summary_extraction_result",
  "x-description": "Conversation summary extraction structured output contract.",
  "additionalProperties": false,
  "properties": {
    "summaryText": {
      "type": "string",
      "minLength": 1
    },
    "skipped": {
      "type": "boolean"
    },
    "reason": {
      "type": ["string", "null"]
    }
  },
  "oneOf": [
    {
      "required": ["summaryText"],
      "properties": {
        "summaryText": {
          "type": "string",
          "minLength": 1
        },
        "skipped": {
          "const": false
        }
      }
    },
    {
      "required": ["skipped"],
      "properties": {
        "skipped": {
          "const": true
        }
      }
    }
  ]
}
