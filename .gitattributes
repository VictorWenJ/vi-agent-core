# Normalize text files in repository checkout/commit flow.
* text=auto

# Project text assets (force text handling + LF in repo).
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.md text eol=lf
mvnw text eol=lf
*.sh text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf
